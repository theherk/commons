copy_on_select false
show_startup_tips false
simplified_ui true
theme "catppuccin-frappe"
default_layout "default"

keybinds {
    unbind "Ctrl n"
    unbind "Ctrl t"
    shared_except "locked" {
        bind "Ctrl a" { SwitchToMode "tab"; }
    }
    normal {
        bind "Ctrl Shift r" { SwitchToMode "resize"; }
        unbind "Ctrl q"
    }
    pane {
        bind "e" { Run "nvp" { close_on_exit true; Direction "Right"; }; SwitchToMode "Normal"; }
        bind "f" { Run "fish" "-c" "yazi" { close_on_exit true; Direction "Right"; }; SwitchToMode "Normal"; }
        bind "g" { Run "lazygit" { close_on_exit true; Direction "Right"; }; SwitchToMode "Normal"; }
        bind "r" { Run "raicode" { close_on_exit true; Direction "Right"; }; SwitchToMode "Normal"; }
        bind "s" { NewPane "Down"; SwitchToMode "Normal"; }
        bind "u" { Run "jjui" { close_on_exit true; Direction "Right"; }; SwitchToMode "Normal"; }
        bind "v" { NewPane "Right"; SwitchToMode "Normal"; }
    }
    scroll {
        bind "y" { Copy; SwitchToMode "normal"; }
    }
    session {
        bind "p" { SwitchToMode "normal"; Run "zellij-project.fish" { floating true; close_on_exit true; }; }
        bind "?" { LaunchOrFocusPlugin "zellij:about" { floating true; }; SwitchToMode "Normal"; }
    }
    tab {
        bind "a" {
            MessagePlugin "file:~/bin/zellij-tab-switcher.wasm" {
                name "switch-tab"
                payload "agent agent"
            }; SwitchToMode "normal";
        }
        bind "b" {
            MessagePlugin "file:~/bin/zellij-tab-switcher.wasm" {
                name "switch-tab"
                payload "browse-repos browse"
            }; SwitchToMode "normal";
        }
        bind "e" {
            MessagePlugin "file:~/bin/zellij-tab-switcher.wasm" {
                name "switch-tab"
                payload "editor editor"
            }; SwitchToMode "normal";
        }
        bind "f" {
            MessagePlugin "file:~/bin/zellij-tab-switcher.wasm" {
                name "switch-tab"
                payload "files yazi"
            }; SwitchToMode "normal";
        }
        bind "g" {
            MessagePlugin "file:~/bin/zellij-tab-switcher.wasm" {
                name "switch-tab"
                payload "git lazygit"
            }; SwitchToMode "normal";
        }
        bind "u" {
            MessagePlugin "file:~/bin/zellij-tab-switcher.wasm" {
                name "switch-tab"
                payload "jj jjui"
            }; SwitchToMode "normal";
        }
        bind "n" { NewTab { layout "default"; }; SwitchToMode "normal"; }
    }
}

plugins {
    about location="zellij:about"
    session-manager location="zellij:session-manager"
}

load_plugins {
    "file:~/bin/zellij-tab-switcher.wasm"
}
