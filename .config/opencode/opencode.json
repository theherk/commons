{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/claude-opus-4.6",
  "small_model": "github-copilot/claude-haiku-4.5",
  "permission": {
    "bash": {
      "*": "allow",
      "git push*": "ask"
    },
    "external_directory": {
      "~/vaults/brain/*": "allow",
      "~/Library/CloudStorage/OneDrive-DNBBankASA/dnbrain/*": "allow",
      "~/projects/*": "allow",
      "/tmp/*": "allow",
      "/var/folders/*": "allow"
    }
  },
  "agent": {
    "build": {
      "color": "error",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow"
      }
    },
    "explore": {
      "color": "success",
      "mode": "primary",
      "description": "Read-only codebase exploration. No writes, minimal bash.",
      "model": "github-copilot/claude-haiku-4.5",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "git log*": "allow",
          "git diff*": "allow",
          "git status*": "allow",
          "git show*": "allow"
        },
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "skill": "allow",
        "task": {
          "*": "deny",
          "jira-work": "allow"
        }
      }
    },
    "plan": {
      "color": "warning",
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    }
  },
  "provider": {
    "omlx": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "oMLX (local)",
      "options": {
        "baseURL": "http://localhost:8000/v1"
      },
      "models": {
        "mlx-community--gemma-4-26b-a4b-it-4bit": {
          "name": "Gemma 4 26B (MLX, 256K context)"
        }
      }
    }
  },
  "mcp": {
    "semble": {
      "type": "local",
      "command": ["uvx", "--from", "semble[mcp]", "semble"]
    },
    "atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp/authv2"
    }
  }
}
