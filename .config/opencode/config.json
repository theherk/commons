{
  "$schema": "https://opencode.ai/config.json",
  "model": "raicode/claude-opus-4-6",
  "permission": {
    "external_directory": {
      "~/vaults/brain/*": "allow",
      "~/Library/CloudStorage/OneDrive-DNBBankASA/dnbrain/*": "allow",
      "~/projects/*": "allow",
      "/tmp/*": "allow",
      "/var/folders/*": "allow"
    }
  },
  "agent": {
    "build": {
      "model": "raicode/claude-opus-4-6",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow"
      }
    },
    "explore": {
      "mode": "primary",
      "description": "Read-only codebase exploration. No writes, minimal bash.",
      "model": "raicode/claude-haiku-4-5-20251001",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "git log*": "allow",
          "git diff*": "allow",
          "git status*": "allow",
          "git show*": "allow"
        },
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "skill": "allow",
        "task": {
          "*": "deny",
          "jira-work": "allow"
        }
      }
    },
    "plan": {
      "model": "raicode/claude-opus-4-6",
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    }
  },
  "mcp": {
    "semble": {
      "type": "local",
      "command": ["uvx", "--from", "semble[mcp]", "semble"]
    }
  }
}
